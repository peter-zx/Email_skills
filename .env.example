# Copy this file to .env. Never commit .env.
#
# Use an app password / authorization code instead of your normal mailbox password.
IMAP_USER=your@qq.com
IMAP_PASSWORD=your_email_app_password
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_REJECT_UNAUTHORIZED=false
MAILBOX=INBOX

# Optional. Used only for generated QQ webmail hyperlinks.
MAIL_WEB_USER=
